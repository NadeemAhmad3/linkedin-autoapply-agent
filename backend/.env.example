# Copy this file to .env and fill in your values.

# --- Apify (job discovery) ---
# Get a token from https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# The Apify actor that scrapes LinkedIn jobs.
# Default: bebity/linkedin-jobs-scraper (well-maintained, returns full data).
# Field names vary per actor; see app/services/apify_client.py normalizer.
APIFY_ACTOR_ID=bebity/linkedin-jobs-scraper

# Default freshness window for "recent jobs" (minutes). 30 = last 30 min.
SEARCH_FRESHNESS_MINUTES=30

# --- Matching ---
# sentence-transformers model used for resume<->job similarity.
MATCH_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Storage ---
DATABASE_URL=sqlite:///./data/app.db

# --- Apply (Phase 4, review-and-confirm) ---
# Profile used to pre-fill Easy Apply forms. Also editable in the UI.
APPLY_EMAIL=
APPLY_PHONE=
APPLY_RESUME_PATH=        # absolute path to a PDF, e.g. C:\resumes\me.pdf
APPLY_YEARS_OF_EXPERIENCE=5
APPLY_EDUCATION_LEVEL=Bachelor's Degree
APPLY_WORK_AUTHORIZATION=Yes
APPLY_REQUIRE_SPONSORSHIP=No
APPLY_WILLING_TO_RELOCATE=Yes
APPLY_NOTICE_PERIOD=15
